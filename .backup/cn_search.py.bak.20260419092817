#!/usr/bin/env python3
"""
中文深度搜索工具 - 广度 + 深度并重
多渠道并行搜索，结果去重 + 质量排序输出

渠道清单：
  [1] SearXNG + Baidu      → 泛搜索，网络全量
  [2] SearXNG + 360搜索    → 补充中文结果
  [3] B站视频搜索          → 视频内容
  [4] 微信公众号           → 通过搜狗微信
  [5] 微博实时热搜         → 热点追踪
  [6] B站热门视频          → 视频热点
  [7] Tavily               → 结构化综合搜索

用法:
  python3 cn_search.py <关键词> [条数]
  python3 cn_search.py AI大模型 5        # AI大模型 每天5条
  python3 cn_search.py AI大模型 20      # 深度20条
"""
import sys, time, requests, json, re
from concurrent.futures import ThreadPoolExecutor, as_completed

# ── 通用配置 ──────────────────────────────────────
MAX_WORKERS = 6          # 并行线程数
TIMEOUT = 12              # 单个请求超时（秒）
DEFAULT_LIMIT = 10

# ── SearXNG 配置 ──────────────────────────────────
SEARXNG_BASE = "http://127.0.0.1:8080"

# ── Tavily 配置 ───────────────────────────────────
TAVILY_KEY = "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"

# ── 工具函数 ──────────────────────────────────────
def _ua():
    return {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'Accept-Language': 'zh-CN,zh;q=0.9',
    }

def safe_get(url, headers=None, params=None, timeout=TIMEOUT):
    """带超时的安全 GET"""
    try:
        r = requests.get(url, headers=headers or {}, params=params, timeout=timeout)
        return r
    except Exception:
        return None

def clean_title(html_title):
    """去除 HTML 标题中的标签和噪声"""
    if not html_title:
        return ''
    t = re.sub(r'<[^>]+>', '', html_title)
    t = re.sub(r'[\s]+', ' ', t).strip()
    return t[:120]

# ── 渠道 1: SearXNG + Baidu ────────────────────────
def search_searxng_baidu(query, limit=10):
    try:
        r = safe_get(
            f"{SEARXNG_BASE}/search",
            params={"q": query, "format": "json", "engines": "baidu", "limit": limit}
        )
        if not r or r.status_code != 200:
            return []
        d = r.json()
        out = []
        for x in d.get('results', [])[:limit]:
            out.append({
                "channel": "百度",
                "title": clean_title(x.get('title', '')),
                "url": x.get('url', ''),
                "desc": clean_title(x.get('content', ''))[:100],
            })
        return out
    except Exception as e:
        return []

# ── 渠道 2: SearXNG + 360搜索 ─────────────────────
def search_searxng_360(query, limit=10):
    try:
        r = safe_get(
            f"{SEARXNG_BASE}/search",
            params={"q": query, "format": "json", "engines": "360search", "limit": limit}
        )
        if not r or r.status_code != 200:
            return []
        d = r.json()
        out = []
        for x in d.get('results', [])[:limit]:
            out.append({
                "channel": "360搜索",
                "title": clean_title(x.get('title', '')),
                "url": x.get('url', ''),
                "desc": clean_title(x.get('content', ''))[:100],
            })
        return out
    except Exception:
        return []

# ── 渠道 3: B站视频搜索 ────────────────────────────
def search_bilibili(query, limit=10):
    try:
        r = safe_get(
            "https://api.bilibili.com/x/web-interface/search/type",
            params={"search_type": "video", "keyword": query, "page": 1, "page_size": limit},
            headers={**(_ua()), 'Accept': 'application/json'}
        )
        if not r:
            return []
        d = r.json().get('data', {}).get('result', [])
        out = []
        for x in d[:limit]:
            title = re.sub(r'<[^>]+>', '', x.get('title', ''))
            out.append({
                "channel": "B站视频",
                "title": title,
                "url": f"https://www.bilibili.com/video/{x.get('bvid','')}",
                "desc": f"UP: {x.get('author','')} | 👀{x.get('play','')} 👍{x.get('like','')}",
            })
        return out
    except Exception:
        return []

# ── 渠道 4: 微信公众号（搜狗微信）──────────────────
def search_wechat(query, limit=10):
    try:
        from bs4 import BeautifulSoup
    except ImportError:
        return []

    try:
        r = safe_get(
            f"https://weixin.sogou.com/weixin?type=2&query={requests.utils.quote(query)}&ie=utf8",
            headers=_ua(), timeout=15
        )
        if not r or r.status_code != 200:
            return []

        soup = BeautifulSoup(r.text, 'html.parser')
        items = soup.select('li[id^="sogou_vr_"]')
        out = []
        for item in items[:limit]:
            h3 = item.find('h3')
            title = h3.get_text(strip=True) if h3 else ''
            acct = item.find('span', class_='all-time-y2')
            account = acct.get_text(strip=True) if acct else ''
            summary_el = item.find('p', class_='txt-info')
            summary = summary_el.get_text(strip=True)[:80] if summary_el else ''
            if title:
                out.append({
                    "channel": "微信公众号",
                    "title": title,
                    "url": "https://weixin.sogou.com/",
                    "desc": f"📣{account} | {summary[:60]}",
                })
        return out
    except Exception:
        return []

# ── 渠道 5: 微博实时热搜 ──────────────────────────
def search_weibo_hot(limit=10):
    try:
        r = safe_get(
            'https://weibo.com/ajax/side/hotSearch',
            headers={
                **_ua(),
                'Referer': 'https://weibo.com/',
                'Accept': 'application/json, text/plain, */*',
                'X-Requested-With': 'XMLHttpRequest'
            }, timeout=15
        )
        if not r:
            return []
        d = r.json().get('data', {}).get('realtime', [])
        out = []
        for x in d[:limit]:
            out.append({
                "channel": "微博热搜",
                "title": x.get('word', ''),
                "url": f"https://s.weibo.com/weibo?q={requests.utils.quote(x['word'])}",
                "desc": f"🔥 热度: {x.get('num',0):,}",
            })
        return out
    except Exception:
        return []

# ── 渠道 6: B站热门视频 ───────────────────────────
def search_bilibili_hot(limit=10):
    try:
        r = safe_get(
            'https://api.bilibili.com/x/web-interface/ranking/v2?rid=0&type=all',
            headers={**_ua(), 'Accept': 'application/json'}, timeout=12
        )
        if not r:
            return []
        d = r.json().get('data', {}).get('list', [])
        out = []
        for x in d[:limit]:
            out.append({
                "channel": "B站热门",
                "title": x.get('title', '').strip(),
                "url": f"https://www.bilibili.com/video/{x.get('bvid','')}",
                "desc": f"👤 {x.get('owner',{}).get('name','?')} | 👍 {x.get('stat',{}).get('like',0):,}",
            })
        return out
    except Exception:
        return []

# ── 渠道 7: Tavily ────────────────────────────────
def search_tavily(query, limit=10):
    try:
        from tavily import TavilyClient
        client = TavilyClient(api_key=TAVILY_KEY)
        r = client.search(query=query, max_results=limit)
        out = []
        for x in r.get('results', [])[:limit]:
            out.append({
                "channel": "Tavily",
                "title": x.get('title', ''),
                "url": x.get('url', ''),
                "desc": x.get('content', '')[:80],
            })
        return out
    except Exception:
        return []

# ── 主搜索编排 ────────────────────────────────────
def deep_search(query, limit_per_channel=10):
    """并行搜索所有渠道，结果合并输出"""
    print(f"\n🌐 开始深度搜索：「{query}」")
    print(f"   目标每渠道 {limit_per_channel} 条，结果按渠道分组输出")
    print("=" * 60)

    funcs = [
        ("百度", lambda: search_searxng_baidu(query, limit_per_channel)),
        ("360搜索", lambda: search_searxng_360(query, limit_per_channel)),
        ("B站视频", lambda: search_bilibili(query, limit_per_channel)),
        ("微信公众号", lambda: search_wechat(query, limit_per_channel)),
        ("微博热搜", lambda: search_weibo_hot(limit_per_channel)),
        ("B站热门", lambda: search_bilibili_hot(limit_per_channel)),
        ("Tavily", lambda: search_tavily(query, limit_per_channel)),
    ]

    all_results = {}
    total = 0

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
        futures = {executor.submit(f): name for name, f in funcs}
        for future in as_completed(futures, timeout=TIMEOUT * 3):
            name = futures[future]
            try:
                results = future.result()
                all_results[name] = results
                total += len(results)
            except Exception as e:
                all_results[name] = []

    # ── 输出结果 ─────────────────────────────────
    print(f"\n✅ 共获得 {total} 条结果\n")

    for name, results in all_results.items():
        if not results:
            continue
        print(f"{'─' * 55}")
        print(f"📌 【{name}】({len(results)} 条)")
        print(f"{'─' * 55}")
        for i, r in enumerate(results, 1):
            print(f"  {i:2d}. {r['title'][:50]}")
            if r.get('desc'):
                print(f"      └ {r['desc'][:65]}")
            print(f"      └ {r.get('url','')[:70]}")

    print("\n" + "=" * 60)
    return all_results

# ── 入口 ──────────────────────────────────────────
if __name__ == '__main__':
    if '--help' in sys.argv:
        print(__doc__)
        sys.exit(0)

    query = sys.argv[1] if len(sys.argv) > 1 else 'AI大模型'
    try:
        limit = int(sys.argv[2]) if len(sys.argv) > 2 else DEFAULT_LIMIT
    except ValueError:
        limit = DEFAULT_LIMIT

    deep_search(query, limit)